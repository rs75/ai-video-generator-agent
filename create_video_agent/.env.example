# Copy this to create_video_agent/.env for local (non-Docker) development.
# With Docker you don't need this file — the project comes from your mounted
# gcloud config (or `-e GOOGLE_CLOUD_PROJECT=...`). See the README.

# --- Vertex AI via Application Default Credentials (ADC) ---
# Run `gcloud auth application-default login` once; no service-account key needed.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Alternative: Google AI Studio (Gemini API) instead of Vertex ---
# Get a key at https://aistudio.google.com/app/apikey, then set:
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_API_KEY=your-gemini-api-key
